# .env.example — Configuración de ejemplo para el Clasificador de Textos
# -----------------------------------------------------------------------------
# Copia este archivo como ".env" y rellena tus valores REALES si quieres usar
# un modelo de lenguaje (LLM) en lugar del clasificador por reglas.
#
# ⚠️ IMPORTANTE:
#   - El archivo ".env" NUNCA debe subirse al repositorio (ponlo en .gitignore).
#   - Estas son claves DUMMY de ejemplo: no funcionan, reemplázalas por las tuyas.
#   - La llamada al LLM debe hacerse desde un BACKEND, no desde el navegador,
#     para no exponer la clave. Sin .env válido, la app usa el modo por reglas.

# Clave de API del proveedor de LLM (OpenAI, etc.). Ejemplo/placeholder:
LLM_API_KEY=tu-api-key-aqui

# Modelo de lenguaje a utilizar.
LLM_MODEL=gpt-3.5-turbo
